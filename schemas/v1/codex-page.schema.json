{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.thinkneverland.com/codex-pdf/v1/codex-page.schema.json",
  "title": "CodexPage",
  "type": "object",
  "required": ["page_num", "rotation", "boxes"],
  "properties": {
    "page_num": { "type": "integer", "minimum": 1 },
    "rotation": { "type": "integer" },
    "boxes": {
      "type": "object",
      "required": ["media"],
      "properties": {
        "media": { "$ref": "codex-box.schema.json" },
        "crop": { "anyOf": [{ "$ref": "codex-box.schema.json" }, { "type": "null" }] },
        "bleed": { "anyOf": [{ "$ref": "codex-box.schema.json" }, { "type": "null" }] },
        "trim": { "anyOf": [{ "$ref": "codex-box.schema.json" }, { "type": "null" }] },
        "art": { "anyOf": [{ "$ref": "codex-box.schema.json" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "properties": {
        "font_ids": { "type": "array", "items": { "type": "string" } },
        "color_space_ids": { "type": "array", "items": { "type": "string" } },
        "xobject_ids": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "inventory": { "type": "array", "items": { "$ref": "codex-page-object.schema.json" } },
    "transparency_tree": { "$ref": "codex-transparency-tree.schema.json" },
    "annotations": { "type": "array", "items": { "type": "string" } },
    "detected_text_regions": {
      "type": "array",
      "items": { "$ref": "codex-detected-text-region.schema.json" },
      "description": "Text regions detected during extraction (cache key: pdf_hash, page_index, dpi)."
    },
    "detected_language": {
      "anyOf": [{ "$ref": "codex-detected-language.schema.json" }, { "type": "null" }],
      "default": null,
      "description": "AI-detected dominant language on the page. Empty when AI is disabled / skipped — check extraction_warnings for ai_disabled / ai_skipped to disambiguate. Cache key: (pdf_hash, page_index, \"language\")."
    },
    "detected_logos": {
      "type": "array",
      "items": { "$ref": "codex-detected-logo.schema.json" },
      "default": [],
      "description": "AI-detected logos / brand marks. Cache key: (pdf_hash, page_index, \"logos\")."
    },
    "detected_symbols": {
      "type": "array",
      "items": { "$ref": "codex-detected-symbol.schema.json" },
      "default": [],
      "description": "AI-detected regulatory / safety / packaging symbols. Cache key: (pdf_hash, page_index, \"symbols\")."
    },
    "detected_barcodes": {
      "type": "array",
      "items": { "$ref": "codex-detected-barcode.schema.json" },
      "default": [],
      "description": "Decoded barcodes (pyzbar / pylibdmtx). Cache key: (pdf_hash, page_index, \"barcodes\")."
    },
    "spell_candidates": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Unknown-word list from the spell-candidate pass. No tenant policy applied — consumers (lint) interpret. Cache key: (pdf_hash, page_index, \"spell\")."
    }
  },
  "additionalProperties": false
}
