{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.thinkneverland.com/codex-pdf/v1/codex-detected-text-region.schema.json",
  "title": "CodexDetectedTextRegion",
  "description": "One text region detected on a page during extraction. Geometry is in PDF user-space points. Cache key: (pdf_hash, page_index, dpi).",
  "type": "object",
  "required": ["bbox"],
  "properties": {
    "bbox": { "$ref": "codex-box.schema.json" },
    "text": { "type": "string", "default": "" },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 1.0 },
    "polygon": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": { "type": "number" }
      },
      "default": []
    },
    "source": { "type": "string", "default": "unknown" }
  },
  "additionalProperties": false
}
