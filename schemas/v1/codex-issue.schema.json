{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.thinkneverland.com/codex-pdf/v1/codex-issue.schema.json",
  "title": "CodexIssue",
  "type": "object",
  "required": ["issue_id", "severity", "message"],
  "properties": {
    "issue_id": { "type": "string" },
    "inspection_id": { "type": ["string", "null"] },
    "severity": { "type": "string", "enum": ["error", "warning", "advisory"] },
    "message": { "type": "string" },
    "page_num": { "type": ["integer", "null"] },
    "source": { "type": ["string", "null"] },
    "details": { "type": "object" }
  },
  "additionalProperties": false
}
