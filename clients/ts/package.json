{
  "name": "@printwithsynergy/codex-client",
  "version": "1.4.1",
  "description": "TypeScript client for the codex-pdf HTTP API. Mirrors the Python codex_pdf.client surface.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "Think Neverland LLC",
  "homepage": "https://github.com/printwithsynergy/codex-pdf#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/printwithsynergy/codex-pdf.git",
    "directory": "clients/ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "tsc -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
